# آدرس و کلید پروژه Supabase (از تنظیمات پروژه در supabase.com قابل دریافت است)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# کلید OpenAI فقط در Edge Function استفاده می‌شود، هرگز در فرانت‌اند قرار نگیرد
# این متغیر باید به‌صورت Secret در Supabase تنظیم شود، نه در این فایل:
# supabase secrets set OPENAI_API_KEY=sk-xxxx
